@app.route('/advanced-search', methods=['GET', 'POST'])
def advanced_search():
    query = request.form.get('query', '') or request.args.get('q', '')
    genre = request.form.get('genre', 'All') or request.args.get('genre', 'All')
    year_min = request.form.get('year_min', '') or request.args.get('year_min', '')
    year_max = request.form.get('year_max', '') or request.args.get('year_max', '')
    rating_min = request.form.get('rating_min', 'All') or request.args.get('rating_min', 'All')
    language = request.form.get('language', 'All') or request.args.get('language', 'All')
    
    filtered_movies = movies.copy()
    
    if query:
        filtered_movies = [m for m in filtered_movies if query.lower() in m['title'].lower()]
    if genre != 'All' and genre:
        filtered_movies = [m for m in filtered_movies if genre.lower() in m['genre'].lower()]
    if year_min and year_min.isdigit():
        filtered_movies = [m for m in filtered_movies if m['year'] >= int(year_min)]
    if year_max and year_max.isdigit():
        filtered_movies = [m for m in filtered_movies if m['year'] <= int(year_max)]
    if rating_min != 'All' and rating_min:
        rating_val = float(rating_min)
        filtered_movies = [m for m in filtered_movies if m['rating'] >= rating_val]
    if language != 'All' and language:
        filtered_movies = [m for m in filtered_movies if m['language'] == language]
    
    all_titles = df['title'].tolist()
    username = session.get('username')
    all_genres = sorted(set([m['genre'] for m in movies]))
    
    return render_template('advanced_search.html',
                         movies=filtered_movies,
                         all_titles=all_titles,
                         total_results=len(filtered_movies),
                         username=username,
                         user=session.get('user'),
                         current_lang='Advanced Search',
                         query=query,
                         genre=genre,
                         year_min=year_min,
                         year_max=year_max,
                         rating_min=rating_min,
                         language=language,
                         all_genres=all_genres)

